{
  "name": "unify-frontend",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "engines": {
    "node": ">=20 <24"
  },
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "start:lan": "expo start --lan",
    "start:tunnel": "expo start --tunnel",
    "start:dev": "node scripts/start-expo-profile.js dev",
    "start:dev-avd-localhost": "node scripts/start-expo-profile.js dev-avd-localhost",
    "start:homolog": "node scripts/start-expo-profile.js homolog",
    "start:prod": "node scripts/start-expo-profile.js prod",
    "android:local": "node scripts/start-expo-profile.js dev-avd-localhost --android-local",
    "android:local:dev": "node scripts/start-expo-profile.js dev --android-local",
    "android:local:dev-avd-localhost": "node scripts/start-expo-profile.js dev-avd-localhost --android-local",
    "android:local:homolog": "node scripts/start-expo-profile.js homolog --android-local",
    "android:local:prod": "node scripts/start-expo-profile.js prod --android-local",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.0",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.0",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^4.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
