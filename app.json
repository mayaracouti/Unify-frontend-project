{
  "expo": {
    "name": "Unify-frontend",
    "slug": "Unify-frontend",
    "scheme": "unify-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-screen.png",
      "resizeMode": "contain",
      "backgroundColor": "#4D52B5"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Unifyfrontend"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita que a Unify acesse suas fotos para atualizar sua imagem de perfil e sua galeria.",
          "cameraPermission": "Permita que a Unify use a câmera para atualizar sua imagem de perfil e sua galeria."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permita que a Unify use sua localização para melhorar a distância dos seus matches."
        }
      ]
    ]
  }
}
