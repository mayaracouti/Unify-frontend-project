# Base defaults for the shared dev profile.
# Optional local overrides live in `.env.dev.local` and are ignored by Git.
EXPO_PUBLIC_APP_PROFILE=dev
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

#descobrir o IP, e trocar o localhost por ele, para funcionar no emulador
#linha 4 --> EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:8080